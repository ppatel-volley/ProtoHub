{
    "name": "@hub/mobile",
    "version": "0.1.6",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "pnpm run build:env-config && tsc -b && vite build",
        "build:env-config": "node scripts/build-env-config.js",
        "clean": "rm -rf dist && rm -rf node_modules",
        "dev": "pnpm run build:env-config && vite --host",
        "format": "eslint --fix",
        "lint": "eslint . && stylelint 'src/**/*.scss'",
        "lint:fix": "eslint . --fix && stylelint 'src/**/*.scss' --fix",
        "lint:scss": "stylelint 'src/**/*.scss'",
        "test": "pnpm run test:unit",
        "test:unit": "jest --coverage",
        "typecheck": "tsc --noEmit",
        "upload:sourcemaps": "datadog-ci sourcemaps upload ./dist --service mobile-client --release-version $npm_package_version --minified-path-prefix /mobile/"
    },
    "dependencies": {
        "@amplitude/experiment-js-client": "^1.15.6",
        "@datadog/browser-logs": "^6.10.1",
        "@datadog/browser-rum": "^6.10.1",
        "@rive-app/canvas": "^2.30.0",
        "@rive-app/react-canvas": "^4.21.3",
        "@vitejs/plugin-legacy": "^6.1.1",
        "@volley/platform-sdk": "7.45.2",
        "@volley/tracking": "^7.39.1",
        "@volley/vgf": "^1.29.0",
        "classnames": "^2.5.1",
        "lottie-react": "^2.4.1",
        "react": "^19.1.0",
        "react-dom": "^19.1.0",
        "react-modal": "^3.16.3",
        "rive-react": "^4.22.0",
        "uuid": "^11.1.0",
        "zod": "^3.25.58"
    },
    "devDependencies": {
        "@datadog/datadog-ci": "^3.20.0",
        "@eslint/compat": "^2.0.2",
        "@hub/eslint-config": "workspace:*",
        "@hub/tsconfig": "workspace:*",
        "@juggle/resize-observer": "^3.4.0",
        "@stylistic/eslint-plugin": "2.7.2",
        "@testing-library/jest-dom": "^6.6.3",
        "@testing-library/react": "^16.3.0",
        "@testing-library/user-event": "^14.6.1",
        "@types/jest": "^29.5.14",
        "@types/node": "^20.19.0",
        "@types/react": "^19.1.7",
        "@types/react-dom": "^19.1.6",
        "@types/react-modal": "^3.16.3",
        "@types/uuid": "^10.0.0",
        "@vitejs/plugin-react-swc": "^3.11.0",
        "core-js": "^3.45.1",
        "dotenv": "^16.4.7",
        "eslint": "^9.28.0",
        "focus-visible": "^5.2.1",
        "fontaine": "^0.6.0",
        "globals": "^15.15.0",
        "identity-obj-proxy": "^3.0.0",
        "intersection-observer": "^0.12.2",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "29.7.0",
        "prettier": "~3.0.3",
        "sass-embedded": "^1.89.2",
        "stylelint": "^16.12.0",
        "stylelint-config-standard-scss": "^14.0.0",
        "stylelint-scss": "^6.10.1",
        "ts-jest": "^29.3.4",
        "ts-node": "^10.9.2",
        "typescript": "~5.7.3",
        "vite": "^6.3.5"
    }
}
