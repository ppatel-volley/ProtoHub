{
    "name": "@hub/client",
    "version": "1.237.2",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "pnpm run build:env-config && tsc -b && vite build",
        "build:env-config": "node scripts/build-env-config.js",
        "build:upload-sourcemaps": "pnpm run build && pnpm run upload:sourcemaps",
        "clean": "rm -rf dist && rm -rf node_modules",
        "dev": "pnpm run build:env-config && vite --host",
        "docs": "typedoc && cp docs/hubsmile.png ../../docs/client/assets/hubsmile.png",
        "docs:open": "open ../../docs/client/index.html",
        "format": "eslint --fix",
        "lint": "eslint . && stylelint 'src/**/*.scss'",
        "lint:fix": "eslint . --fix && stylelint 'src/**/*.scss' --fix",
        "lint:scss": "stylelint 'src/**/*.scss'",
        "pre-release": "semantic-release --dry-run",
        "preview": "vite preview --base=/hub/",
        "release": "semantic-release",
        "serve:prod": "pnpm run preview",
        "start:prod": "pnpm run build && pnpm run serve:prod",
        "test": "pnpm run test:unit && pnpm run test:functional",
        "test:agentic": "pnpm run build && playwright test --config=test/agentic/playwright.agentic.config.ts",
        "test:agentic:headed": "HEADED=true pnpm run test:agentic",
        "test:agentic:nobuild": "playwright test --config=test/agentic/playwright.agentic.config.ts",
        "test:agentic:nobuild:headed": "HEADED=true pnpm run test:agentic:nobuild",
        "test:agentic:staging": "TEST_ENVIRONMENT=staging TEST_BASE_URL=https://game-clients-staging.volley.tv/hub/ playwright test --config=test/agentic/playwright.agentic.config.ts",
        "test:functional": "pnpm run build && playwright test",
        "test:functional:debug": "playwright test --debug",
        "test:functional:nobuild": "playwright test",
        "test:functional:staging": "TEST_ENVIRONMENT=staging TEST_BASE_URL=https://game-clients-staging.volley.tv/hub/ playwright test",
        "test:functional:ui": "playwright test --ui",
        "test:unit": "jest --coverage",
        "typecheck": "tsc --noEmit",
        "upload:sourcemaps": "datadog-ci sourcemaps upload ./dist --service hub-client --release-version $npm_package_version --minified-path-prefix /hub/"
    },
    "dependencies": {
        "@amplitude/experiment-js-client": "^1.15.6",
        "@capacitor/splash-screen": "^7.0.1",
        "@datadog/browser-logs": "^6.10.1",
        "@datadog/browser-rum": "^6.10.1",
        "@hub/server": "workspace:*",
        "@noriginmedia/norigin-spatial-navigation": "^2.3.0",
        "@rive-app/canvas": "^2.30.0",
        "@rive-app/react-canvas": "^4.21.3",
        "@types/react-modal": "^3.16.3",
        "@vitejs/plugin-legacy": "^6.1.1",
        "@volley/platform-sdk": "7.48.1",
        "@volley/tracking": "^7.43.0",
        "@volley/vgf": "^1.29.0",
        "classnames": "^2.5.1",
        "dompurify": "^3.3.1",
        "howler": "^2.2.4",
        "lottie-react": "^2.4.1",
        "motion": "^12.23.22",
        "react": "^19.1.0",
        "react-dom": "^19.1.0",
        "react-modal": "^3.16.3",
        "rive-react": "^4.22.0",
        "uuid": "^11.1.0",
        "zod": "^3.25.58"
    },
    "devDependencies": {
        "@datadog/datadog-ci": "^3.20.0",
        "@eslint/compat": "^2.0.2",
        "@hub/eslint-config": "workspace:*",
        "@hub/tsconfig": "workspace:*",
        "@juggle/resize-observer": "^3.4.0",
        "@playwright/test": "^1.53.0",
        "@semantic-release/changelog": "^6.0.3",
        "@semantic-release/commit-analyzer": "^9.0.2",
        "@semantic-release/exec": "^6.0.3",
        "@semantic-release/git": "^10.0.1",
        "@semantic-release/release-notes-generator": "^10.0.3",
        "@stylistic/eslint-plugin": "2.7.2",
        "@testing-library/jest-dom": "^6.6.3",
        "@testing-library/react": "^16.3.0",
        "@testing-library/user-event": "^14.6.1",
        "@types/dompurify": "^3.2.0",
        "@types/howler": "^2.2.12",
        "@types/jest": "^29.5.14",
        "@types/lodash": "^4.17.17",
        "@types/node": "^20.19.0",
        "@types/react": "^19.1.7",
        "@types/react-dom": "^19.1.6",
        "@types/uuid": "^10.0.0",
        "@vitejs/plugin-react-swc": "^3.11.0",
        "core-js": "^3.45.1",
        "dotenv": "^16.4.7",
        "eslint": "^9.28.0",
        "focus-visible": "^5.2.1",
        "fontaine": "^0.6.0",
        "globals": "^15.15.0",
        "identity-obj-proxy": "^3.0.0",
        "intersection-observer": "^0.12.2",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "29.7.0",
        "msw": "^2.10.2",
        "openai": "^4.77.0",
        "prettier": "~3.0.3",
        "sass-embedded": "^1.89.2",
        "semantic-release": "^22.0.12",
        "sort-package-json": "^2.15.1",
        "stylelint": "^16.12.0",
        "stylelint-config-standard-scss": "^14.0.0",
        "stylelint-scss": "^6.10.1",
        "ts-jest": "^29.3.4",
        "ts-node": "^10.9.2",
        "typedoc": "^0.28.17",
        "typedoc-plugin-markdown": "^4.10.0",
        "typedoc-plugin-mermaid": "^1.12.0",
        "typescript": "~5.7.3",
        "vite": "^6.3.5"
    }
}
