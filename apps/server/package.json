{
    "name": "@hub/server",
    "version": "1.237.2",
    "private": true,
    "exports": {
        ".": "./src/shared/index.ts",
        "./types": "./src/shared/types/index.ts"
    },
    "scripts": {
        "build": "node ./esbuild.config.mjs",
        "clean": "rm -rf dist && rm -rf node_modules",
        "dev": "node ./esbuild.dev.config.mjs",
        "format": "eslint --fix",
        "lint": "eslint .",
        "pre-release": "semantic-release --dry-run",
        "release": "semantic-release",
        "start": "node dist/index.js",
        "test": "pnpm run test:unit && pnpm run test:functional",
        "test:functional": "playwright test",
        "test:unit": "jest",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@hub/eslint-config": "workspace:*",
        "@hub/tsconfig": "workspace:*",
        "@volley/vgf": "1.17.0",
        "cors": "^2.8.5",
        "date-fns": "^4.1.0",
        "dotenv": "^16.4.7",
        "express": "^4.21.2",
        "ioredis": "^5.6.1",
        "uuid": "^11.1.0",
        "zod": "^3.24.2"
    },
    "devDependencies": {
        "@es-exec/esbuild-plugin-start": "^0.0.5",
        "@playwright/test": "^1.52.0",
        "@semantic-release/changelog": "^6.0.3",
        "@semantic-release/commit-analyzer": "^9.0.2",
        "@semantic-release/exec": "^6.0.3",
        "@semantic-release/git": "^10.0.1",
        "@semantic-release/release-notes-generator": "^10.0.3",
        "@swc/core": "^1.11.21",
        "@swc/jest": "^0.2.37",
        "@types/cors": "^2.8.17",
        "@types/express": "^5.0.0",
        "@types/jest": "^29.5.14",
        "@types/node": "^20.10.5",
        "@types/supertest": "^6.0.3",
        "@types/uuid": "^10.0.0",
        "esbuild": "0.25.0",
        "eslint": "^9.21.0",
        "jest": "^29.7.0",
        "rimraf": "^5.0.5",
        "semantic-release": "^22.0.7",
        "supertest": "^7.1.0",
        "ts-jest": "^29.2.6",
        "typescript": "^5.3.3"
    }
}
